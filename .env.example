# Copy this file to .env in the same directory and fill in real values.
# The compose file refuses to start without these — every secret is now
# externalised so the git history never carries real credentials.
#
# Generate strong values locally:
#   openssl rand -base64 24      → POSTGRES/MONGO/REDIS_PASSWORD
#   openssl rand -base64 32      → JWT_SECRET_KEY (must be >= 32 bytes)

ASPNETCORE_ENVIRONMENT=Development

POSTGRES_DB=developer_evaluation
POSTGRES_USER=developer
POSTGRES_PASSWORD=change-me-locally

MONGO_USER=developer
MONGO_PASSWORD=change-me-locally

REDIS_PASSWORD=change-me-locally

# Minimum 32 bytes of random data. Re-issuing this invalidates every
# outstanding token, which is the desired behaviour after a rotation.
JWT_SECRET_KEY=replace-with-32-or-more-random-bytes-base64
